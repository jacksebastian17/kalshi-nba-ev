# Kalshi API Credentials (RSA-PSS Authentication)
# Get your Key ID and private key from Kalshi settings
KALSHI_KEY_ID=your_key_id_here
KALSHI_KEY_FILE=/path/to/your/kalshi-key.pem

# The Odds API Credentials (for fetching Pinnacle moneylines)
# Sign up free at https://the-odds-api.com/
# Free tier: 500 requests/month
# Get a key from your account dashboard
ODDS_API_KEY=your_odds_api_key_here
